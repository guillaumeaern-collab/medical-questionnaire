<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Questionnaire</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>
    <div class="page-shell">
        <main class="card">
            <h1 class="page-title">Questionnaire Médical</h1>

            <% if (typeof message !== 'undefined') { %>
                <p class="alert"><strong><%= message %></strong></p>
            <% } %>

            <% if (typeof showSummary !== 'undefined' && showSummary) { %>
                <div class="summary-box">
                    <div class="question-header">
                        <h2>📋 Résumé de vos réponses</h2>
                    </div>
                    <div class="summary-list">
                        <div class="summary-item">
                            <strong>Nom :</strong> <%= nom %> <%= prenom %> | <strong>Âge :</strong> <%= age %>
                        </div>
                        <% if (typeof responses !== 'undefined') { %>
                            <% if (responses.q1) { %>
                                <div class="summary-item">
                                    <strong>Question 1 :</strong> <%= responses.q1 %>
                                </div>
                            <% } %>
                            <% if (responses.q2) { %>
                                <div class="summary-item">
                                    <strong>Question 2 :</strong> <%= responses.q2 %>
                                </div>
                            <% } %>
                            <% if (responses.q3) { %>
                                <div class="summary-item">
                                    <strong>Question 3 :</strong> <%= responses.q3 %>
                                </div>
                            <% } %>
                        <% } %>
                    </div>

                    <form action="/submit-questionnaire" method="POST" class="actions">
                        <input type="hidden" name="nom" value="<%= nom %>">
                        <input type="hidden" name="prenom" value="<%= prenom %>">
                        <input type="hidden" name="age" value="<%= age %>">
                        <input type="hidden" name="responses" value="<%= JSON.stringify(typeof responses !== 'undefined' ? responses : {}) %>">
                        <input type="submit" value="✉️ Valider mes réponses">
                    </form>
                </div>
            <% } else if (typeof currentQuestion !== 'undefined' && currentQuestion) { %>
                <div class="question-card">
                    <div class="question-header">
                        <h2><%= currentQuestion.label %></h2>
                    </div>

                    <form action="/question-response" method="POST">
                        <input type="hidden" name="questionId" value="<%= currentQuestion.id %>">
                        <input type="hidden" name="nom" value="<%= nom %>">
                        <input type="hidden" name="prenom" value="<%= prenom %>">
                        <input type="hidden" name="age" value="<%= age %>">
                        <input type="hidden" name="responsesJSON" value="<%= JSON.stringify(typeof responses !== 'undefined' ? responses : {}) %>">

                        <% if (currentQuestion.type === 'text') { %>
                            <div class="field-group">
                                <label for="response">Votre réponse :</label>
                                <input type="text" id="response" name="response" placeholder="Entrez votre réponse" required>
                            </div>
                        <% } else if (currentQuestion.type === 'multiple') { %>
                            <div class="field-group">
                                <label>Sélectionnez une option :</label>
                                <div class="option-list">
                                    <% currentQuestion.options.forEach(option => { %>
                                        <div class="option-row">
                                            <input type="radio" id="<%= option %>" name="response" value="<%= option %>" required>
                                            <label for="<%= option %>"><%= option %></label>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>
                        <% } %>

                        <input type="submit" value="Soumettre">
                    </form>
                </div>
            <% } else { %>
                <p class="message success">Questionnaire complété ! Merci.</p>
            <% } %>
        </main>

        <%- include('partials/footer') %>
    </div>
</body>
</html>