<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirmation</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>
    <div class="page-shell">
        <main class="card">
            <h1 class="page-title">Merci pour votre participation</h1>

            <% if (typeof message !== 'undefined') { %>
                <p class="message success"><strong><%= message %></strong></p>
            <% } %>

            <p class="intro">Votre questionnaire a bien été enregistré. Nous vous remercions pour votre temps.</p>

            <div class="actions">
                <a class="btn btn-primary" href="/">Retour à l’accueil</a>
            </div>
        </main>

        <%- include('partials/footer') %>
    </div>
</body>
</html>