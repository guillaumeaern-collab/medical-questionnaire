<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enregistrement Médical</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>
    <div class="page-shell">
        <main class="card">
            <h1 class="page-title">Formulaire d’enregistrement médical</h1>
            <p class="intro">Veuillez renseigner vos informations pour commencer le questionnaire.</p>

            <% if (typeof error !== 'undefined') { %>
                <div class="alert"><%= error %></div>
            <% } %>

            <form action="/enregistrement" method="POST">
                <div class="form-grid">
                    <div class="field-group">
                        <label for="name">Nom :</label>
                        <input type="text" id="name" name="nom" value="<% if (typeof nom !== 'undefined') { %><%= nom %><% } %>" required>
                    </div>

                    <div class="field-group">
                        <label for="prenom">Prénom :</label>
                        <input type="text" id="prenom" name="prenom" value="<% if (typeof prenom !== 'undefined') { %><%= prenom %><% } %>" required>
                    </div>

                    <div class="field-group">
                        <label for="age">Âge :</label>
                        <input type="number" id="age" name="age" value="<% if (typeof age !== 'undefined') { %><%= age %><% } %>" required>
                    </div>
                </div>

                <div class="actions">
                    <input type="submit" value="Commencer le questionnaire">
                </div>
            </form>
        </main>

        <%- include('partials/footer') %>
    </div>
</body>
</html>